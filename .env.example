# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=convoy
DB_PASSWORD=stuffnthings
DB_NAME=convoy_db
DB_SSLMODE=disable

# Map Provider
MAP_PROVIDER=mapbox
MAPBOX_API_KEY=your_mapbox_api_key_change_this_in_production

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=24h

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Frontend Configuration (for Docker build)
VITE_API_URL=http://localhost:8080/api/v1
VITE_MAPBOX_TOKEN=your_mapbox_token_here
